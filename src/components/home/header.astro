---
import headerImg from "../../assets/img/headerImg.jpg";
---

<header
  class="relative h-screen bg-cover bg-center"
  style={{ backgroundImage: `url(${headerImg.src})` }}
>
  <div class="absolute inset-0 bg-black/70"></div>
  <main
    class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
  >
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">CRD Advogado</h1>
    <p class="text-lg md:text-2xl text-white mb-8 max-w-2xl">
      Nós promovemos soluções legais para nossos cliente através de consultoria, negociação e postulação a órgão do Poder Judiciário.
    </p>
    <a
      href="/cassiusadv/contact"
      class="px-6 py-3 bg-[#0B2545] hover:bg-[#1D3A75] text-white font-semibold rounded-3xl transition"
    >
      Contato
    </a>
  </main>
</header>
